{
	"name": "tg-markdown-export-plugin",
	"version": "0.6.0",
	"description": "Export markdown files to properly formatted telegram messages.",
	"main": "main.js",
	"scripts": {
		"dev": "bun esbuild.config.mjs",
		"build": "tsc -noEmit -skipLibCheck && bun esbuild.config.mjs production",
		"version": "bun version-bump.mjs && git add manifest.json versions.json",
		"typecheck": "tsc --noEmit -skipLibCheck"
	},
	"keywords": [],
	"author": "",
	"license": "MIT",
	"devDependencies": {
		"@typescript-eslint/eslint-plugin": "8.59.1",
		"@typescript-eslint/parser": "8.59.1",
		"builtin-modules": "3.3.0",
		"esbuild": "0.28.0",
		"obsidian": "^1.12.3",
		"tslib": "2.8.1",
		"typescript": "6.0.3"
	},
	"dependencies": {
		"@types/bun": "^1.3.13"
	}
}
