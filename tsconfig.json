{
  "compilerOptions": {
    "inlineSourceMap": true,
    "inlineSources": true,
    "module": "Node16",
    "target": "es2019",
    "allowJs": true,
    "noImplicitAny": true,
    "moduleResolution": "node16",
    "types": [
      "bun"
    ],
    "importHelpers": true,
    "isolatedModules": true,
    "strictNullChecks": true,
    "lib": [
      "DOM",
      "ES5",
      "ES2019",
      "ES7"
    ]
  },
  "include": [
    "**/*.ts"
  ]
}
